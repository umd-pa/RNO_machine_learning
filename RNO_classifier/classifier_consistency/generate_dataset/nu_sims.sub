# ----------------------------------------------------------------------
# sims.sub
# ----------------------------------------------------------------------
universe = vanilla
executable = /data/condor_shared/users/ssued/mlvenv/bin/python

# Mimicking Slurm hardware requirements
request_cpus = 1
request_memory = 3G
request_disk = 3G

# ----------------------------------------------------------------------
# PATH DEFINITIONS
# ----------------------------------------------------------------------
IN_DIR = $(input)/nu
OUT_DIR = $(output_base)

SCRIPT_PATH = $(step2)
HW_PATH = $(hw_path)
STATION_JSON = $(station)
CONFIG_YAML = $(config)

# ----------------------------------------------------------------------
# PADDING THE JOB ID
# ----------------------------------------------------------------------
# $(Process) automatically counts from 0 to 99 during the queue.
# $INT(Process,%06d) pads that number with zeros (e.g., 0 -> 000000, 15 -> 000015) (Can add + value to TEMP_ID for index skipping)
TEMP_ID = $(Process)
FILE_ID = $INT(TEMP_ID,%06d)

# ----------------------------------------------------------------------
# EXECUTION COMMAND
# ----------------------------------------------------------------------
# for nu
arguments = "$(SCRIPT_PATH) $(IN_DIR)/nu_f$(FILE_ID).hdf5 $(STATION_JSON) $(CONFIG_YAML) $(OUT_DIR)/nu_f$(FILE_ID).hdf5 $(OUT_DIR)/nu_f$(FILE_ID).nur --threshold 0.1 --trig_chan 40" --hw_path $(hw_path)
# for noise
# arguments = "$(SCRIPT_PATH) $(IN_DIR)/nu_f$(FILE_ID).hdf5 $(STATION_JSON) $(CONFIG_YAML) $(OUT_DIR)/nu/nur/nu_f$(FILE_ID).hdf5 $(OUT_DIR)/nu/nur/nu_f$(FILE_ID).nur --threshold 0.01 --trig_chan 0" --hw_path $(hw_path)
# ----------------------------------------------------------------------
# HOUSEKEEPING
# ----------------------------------------------------------------------
output = $(OUT_DIR)/nu/logs/nu_f$(FILE_ID).out
error  = $(OUT_DIR)/nu/logs/nu_f$(FILE_ID).out
log    = $(OUT_DIR)/nu/logs/nu_f$(FILE_ID).log

# Submit 100 parallel jobs (Process 0 through 99)
queue 100